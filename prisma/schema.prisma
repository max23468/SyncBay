// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum ShopInstallationStatus {
  INSTALLED
  UNINSTALLED
  RECONNECT_REQUIRED
}

enum EbayConnectionStatus {
  NOT_CONNECTED
  CONNECTED
  EXPIRED
  REVOKED
  RECONNECT_REQUIRED
}

enum SyncJobType {
  IMPORT_CATALOG
  SYNC_INCREMENTAL
  UPDATE_EBAY_STOCK
  DETECT_SHOPIFY_CHANGES
  ARCHIVE_INACTIVE_LISTING
  RECONCILE_CATALOG
  CLEANUP_STAGING
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  RETRYING
  CANCELLED
}

enum ProductMappingStatus {
  ACTIVE
  ARCHIVED
  PAUSED
  ERROR
}

enum ProductSnapshotSource {
  EBAY
  SHOPIFY
  SYNCBAY
}

enum SyncConflictStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum SyncConflictResolution {
  KEEP_SHOPIFY
  REALIGN_FROM_EBAY
  IGNORE_FIELD
}

enum EbayAccountDeletionRequestStatus {
  PROCESSING
  PROCESSED
  NO_MATCH
  FAILED
}

enum AuditEventType {
  SHOP_INSTALLED
  SHOP_UNINSTALLED
  SHOPIFY_SCOPES_UPDATED
  SHOPIFY_WEBHOOK_RECEIVED
  EBAY_CONNECT_STARTED
  EBAY_CONNECTED
  EBAY_DISCONNECTED
  EBAY_REFRESH_FAILED
  SYNC_JOB_CREATED
  SYNC_JOB_FAILED
  SYNC_JOB_SUCCEEDED
  CONNECTION_CHECK
  EBAY_ACCOUNT_DELETION_RECEIVED
  EBAY_ACCOUNT_DELETION_PROCESSED
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model Shop {
  id                 String                 @id @default(cuid())
  shopDomain         String                 @unique
  installationStatus ShopInstallationStatus @default(INSTALLED)
  shopifyScopes      String?
  defaultLocationGid String?
  syncEnabled        Boolean                @default(false)
  syncTargetSeconds  Int                    @default(300)
  installedAt        DateTime               @default(now())
  uninstalledAt      DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  ebayConnections  EbayConnection[]
  ebayOAuthStates  EbayOAuthState[]
  syncJobs         SyncJob[]
  auditLogs        AuditLog[]
  productMappings  ProductMapping[]
  productSnapshots ProductSnapshot[]
  syncConflicts    SyncConflict[]
}

model EbayConnection {
  id                    String               @id @default(cuid())
  shopId                String
  marketplaceId         String               @default("EBAY_IT")
  environment           String               @default("sandbox")
  status                EbayConnectionStatus @default(NOT_CONNECTED)
  ebayUserId            String?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  refreshTokenExpiresAt DateTime?
  scopes                String?
  connectedAt           DateTime?
  lastRefreshAt         DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, marketplaceId])
  @@index([status])
}

model EbayOAuthState {
  id         String    @id @default(cuid())
  shopId     String
  stateHash  String    @unique
  returnTo   String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, expiresAt])
}

model SyncJob {
  id             String        @id @default(cuid())
  shopId         String
  type           SyncJobType
  status         SyncJobStatus @default(PENDING)
  providerJobId  String?
  idempotencyKey String?       @unique
  payload        Json?
  result         Json?
  errorCode      String?
  errorMessage   String?
  attempts       Int           @default(0)
  maxAttempts    Int           @default(5)
  runAfter       DateTime      @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status, runAfter])
  @@index([type, status])
}

model ProductMapping {
  id                String               @id @default(cuid())
  shopId            String
  marketplaceId     String               @default("EBAY_IT")
  ebayItemId        String
  sku               String?
  shopifyProductGid String?
  shopifyVariantGid String?
  status            ProductMappingStatus @default(ACTIVE)
  lastSyncedAt      DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  shop      Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  snapshots ProductSnapshot[]
  conflicts SyncConflict[]

  @@unique([shopId, marketplaceId, ebayItemId])
  @@index([shopId, status])
  @@index([shopifyProductGid])
  @@index([sku])
}

model ProductSnapshot {
  id                String                @id @default(cuid())
  shopId            String
  mappingId         String?
  source            ProductSnapshotSource
  ebayItemId        String?
  shopifyProductGid String?
  shopifyVariantGid String?
  sku               String?
  title             String?
  priceAmount       Decimal?              @db.Decimal(12, 2)
  currency          String?
  quantity          Int?
  productStatus     String?
  descriptionHash   String?
  imageCount        Int?
  payload           Json?
  capturedAt        DateTime              @default(now())

  shop    Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  mapping ProductMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)

  @@index([shopId, capturedAt])
  @@index([mappingId, capturedAt])
  @@index([source])
}

model SyncConflict {
  id               String                  @id @default(cuid())
  shopId           String
  mappingId        String?
  field            String
  status           SyncConflictStatus      @default(OPEN)
  resolution       SyncConflictResolution?
  ebayValue        Json?
  lastSyncBayValue Json?
  shopifyValue     Json?
  detectedAt       DateTime                @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  shop    Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  mapping ProductMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)

  @@index([shopId, status, detectedAt])
  @@index([mappingId, status])
}

model AuditLog {
  id        String         @id @default(cuid())
  shopId    String?
  type      AuditEventType
  message   String
  details   Json?
  createdAt DateTime       @default(now())

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([shopId, createdAt])
  @@index([type, createdAt])
}

model EbayAccountDeletionRequest {
  id                  String                           @id @default(cuid())
  notificationId      String                           @unique
  hashedUserId        String
  status              EbayAccountDeletionRequestStatus @default(PROCESSING)
  matchedShopCount    Int                              @default(0)
  signatureKeyId      String?
  publishAttemptCount Int?
  eventDate           DateTime?
  publishDate         DateTime?
  receivedAt          DateTime                         @default(now())
  processedAt         DateTime?
  failureCode         String?
  failureMessage      String?
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt

  @@index([hashedUserId, receivedAt])
  @@index([status, receivedAt])
}
