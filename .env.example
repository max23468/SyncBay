# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_DEV_STORE=syncbay-dev.myshopify.com
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_locations,write_locations

# eBay
# Usa il keyset dedicato SyncBay. Non riusare keyset di altri progetti.
EBAY_ENVIRONMENT=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=
# URL pubblici da completare quando esiste un URL Vercel stabile.
EBAY_OAUTH_ACCEPT_URL=
EBAY_OAUTH_REJECT_URL=
EBAY_OAUTH_ENABLED=false
EBAY_MARKETPLACE_ID=EBAY_IT
EBAY_SCOPES="https://api.ebay.com/oauth/api_scope/commerce.identity.readonly https://api.ebay.com/oauth/api_scope/sell.inventory.readonly https://api.ebay.com/oauth/api_scope/sell.inventory"
EBAY_ACCOUNT_DELETION_ENDPOINT_URL=
EBAY_ACCOUNT_DELETION_VERIFICATION_TOKEN=
# Impostare true solo dopo avere configurato env e endpoint nel portale eBay.
EBAY_ACCOUNT_DELETION_NOTIFICATIONS_ENABLED=false

# SyncBay runtime feature flags
SYNCBAY_DRAFT_IMPORT_ENABLED=false
SYNCBAY_DRAFT_IMPORT_LIMIT=3

# Database
DATABASE_URL=
DATABASE_DIRECT_URL=

# Supabase
SUPABASE_URL=
# Server-side only. Never expose in browser/client bundles.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=syncbay-import-staging

# Security
APP_SECRET=
TOKEN_ENCRYPTION_KEY=

# Jobs
JOB_QUEUE_PROVIDER=supabase_queues
JOB_SCHEDULER_PROVIDER=supabase_cron
SYNC_POLL_INTERVAL_SECONDS=300
